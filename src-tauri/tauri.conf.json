{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "collab",
  "version": "../package.json",
  "identifier": "com.azazel.collab",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "collab",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "zoomHotkeysEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIzNDBEMUU5NTE1RjdFNzIKUldSeWZsOVI2ZEZBc3hIN0VVUlVkWllvK2JFeWhzRSttMXNwRWsrY2JDZFZnREN2YjZ5Y21ZcmMK",
      "endpoints": [
        "https://github.com/Azazel55605/collab/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
